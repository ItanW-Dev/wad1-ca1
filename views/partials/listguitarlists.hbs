
<section class="ui left aligned middle aligned segment">
  
  <section class="dashboard-header">
    <h2 class="title">Guitar Collection Dashboard</h2>
    <form action="/searchCategory" method="GET" class="ui form">
        
      <div class="ui inline fields">
        <div class="field">
          <input type="text" name="searchTerm" placeholder="Search by series..." value="{{search}}">
        </div>

        <div class="field">
          <label>Sort by:</label>
          <select class="ui dropdown" name="sort" onchange="this.form.submit()">
            <option value="title" {{#if titleSelected}}selected{{/if}}>Title</option>
          </select>
        </div>

        <div class="field">
          <label>Order:</label>
          <select class="ui dropdown" name="order" onchange="this.form.submit()">
            <option value="asc" {{#if ascSelected}}selected{{/if}}>↑</option>
            <option value="desc" {{#if descSelected}}selected{{/if}}>↓</option>
          </select>
        </div>
      </div>

    </form>
  </section>
  {{#unless search}}
  {{#unless guitars}}
    <h3 class="ui message">
      Start adding your guitars!
    </h3>
  {{/unless}}
{{/unless}}
  <!-- Loop through each guitar collection/series -->
  {{#each guitars}}
    <section class="ui left aligned middle aligned segment">

      <h3 class="ui header">
        {{uppercase series}}
      </h3>
      {{#unless guitars.length}}
        <p>
          Empty series!
        </p>
        {{else}}
        <!-- Display count and link to guitar details -->
        <p>{{guitars.length}} guitars</p>
      {{/unless}}
      {{#if date}}
        <br>
        <i class="calendar alternate outline icon"></i>
        Created on <i>{{formatDate date}}</i>
    {{/if}}
      <a href="/guitar/{{id}}" ><i class="folder open black outline icon"></i></a>
      <a href="/dashboard/deleteguitarlist/{{id}}">
   <i class="ui trash black icon"></i>
</a>


    </section>
  {{/each}}

</section>
